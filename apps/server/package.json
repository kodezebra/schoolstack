{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:css": "tailwindcss -i ./src/global.css -o ./public/style.css --watch",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "bunx wrangler d1 create kidzkave-db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bunx wrangler d1 migrations apply kidzkave-db --local",
    "db:migrate:remote": "bunx wrangler d1 migrations apply kidzkave-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@libsql/client": "^0.17.0",
    "@tailwindcss/cli": "^4.2.1",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.3",
    "wrangler": "^4.4.0"
  }
}